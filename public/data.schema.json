{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "array",
    "uniqueItemProperties": [
        "keyword"
    ],
    "items": {
        "type": "object",
        "required": [
            "name",
            "keyword",
            "title",
            "category",
            "description"
        ],
        "properties": {
            "name": {
                "type": "string",
                "minLength": 1,
                "description": "동아리/소모임의 이름"
            },
            "keyword": {
                "type": "string",
                "minLength": 1,
                "description": "고유 식별자로 사용될 키워드 영문명 (중복 불가)"
            },
            "title": {
                "type": "string",
                "minLength": 1,
                "description": "게시글 목록에 표시될 제목"
            },
            "category": {
                "type": "string",
                "description": "소속 카테고리 (예: 문화 체험, 운동 등)"
            },
            "deadline": {
                "type": "string",
                "pattern": "^(\\d{4}-\\d{2}-\\d{2})?$",
                "description": "YYYY-MM-DD 형식의 마감일. 상시 모집 등 마감일이 없는 경우는 빈 문자열 허용."
            },
            "description": {
                "type": "string",
                "minLength": 1,
                "description": "동아리 요약 설명"
            },
            "tags": {
                "type": "array",
                "items": {
                    "type": "string"
                },
                "uniqueItems": true,
                "description": "검색에 도움을 주는 해시태그 목록"
            }
        }
    }
}